// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: sessions
// Document ID: sessionId (auto-generated)
// Fields:
//   - userId: string (required) - UID of the owner
//   - createdAt: timestamp (required) - Session start time
//   - status: string (required) - 'active' or 'completed'
//
// Collection: sessions/{sessionId}/logs
// Document ID: logId (auto-generated)
// Fields:
//   - sessionId: string (required) - Parent session ID
//   - timestamp: timestamp (required) - Entry time
//   - type: string (required) - 'voice', 'vision', 'system'
//   - content: string (required) - Text content
//   - metadata: map (optional) - Extra data
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isSessionOwner(sessionId) {
      return isAuthenticated() && get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId == request.auth.uid;
    }

    function isValidSession(data) {
      return data.userId is string && 
             data.createdAt is timestamp &&
             data.status in ['active', 'completed'];
    }

    function isValidLog(data) {
      return data.sessionId is string &&
             data.timestamp is timestamp &&
             data.type in ['voice', 'vision', 'system', 'user', 'aura'] &&
             data.content is string &&
             data.content.size() < 10000;
    }

    // Sessions Collection
    match /sessions/{sessionId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuthenticated() && 
                      request.resource.data.userId == request.auth.uid &&
                      isValidSession(request.resource.data);
      allow update: if isOwner(resource.data.userId) && 
                      isValidSession(request.resource.data);
      
      // Logs Subcollection
      match /logs/{logId} {
        allow read: if isSessionOwner(sessionId);
        allow create: if isSessionOwner(sessionId) && 
                        isValidLog(request.resource.data);
        allow update: if isSessionOwner(sessionId) && 
                        isValidLog(request.resource.data) &&
                        request.resource.data.sessionId == resource.data.sessionId &&
                        request.resource.data.type == resource.data.type;
      }
    }

    // Test connection path
    match /test/connection {
      allow read: if true;
    }
  }
}
